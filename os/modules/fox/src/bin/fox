#!/usr/bin/env bash
# fox — sideral operator CLI (bash dispatcher around `just`).
# Reads SIDERAL_JUSTFILE and SIDERAL_OS_RELEASE from env (test injection).
set -euo pipefail

JUSTFILE="${SIDERAL_JUSTFILE:-/usr/share/sideral/sideral.justfile}"
OS_RELEASE="${SIDERAL_OS_RELEASE:-/etc/os-release}"

case "${1:-}" in
    ""|-h|--help)
        exec just -f "$JUSTFILE" --list
        ;;
    -V|--version)
        awk -F= '/^VERSION_ID=/ {gsub(/"/,"",$2); print $2}' "$OS_RELEASE"
        ;;
    home)
        if [[ $# -lt 2 ]]; then
            exec just -f "$JUSTFILE" --list home
        else
            sub="$2"
            shift 2
            exec just -f "$JUSTFILE" "home::$sub" "$@"
        fi
        ;;
    *)
        exec just -f "$JUSTFILE" "$@"
        ;;
esac
