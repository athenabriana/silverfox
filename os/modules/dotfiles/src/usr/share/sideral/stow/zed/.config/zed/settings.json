// ~/.config/zed/settings.json — sideral image default.
//
// Symlinked from /usr/share/sideral/stow/zed/.config/zed/settings.json by
// GNU stow on first login. The symlink targets a read-only ostree path —
// to customize, replace the symlink with a real file and edit. To restore
// the sideral default, delete your copy and run `ujust apply-defaults`.
//
// JSONC: trailing commas and // comments are accepted by Zed's parser.
{
  // Modal editing — vim emulation is the gate.
  "vim_mode": true,

  "vim": {
    // Start every buffer in Helix-style normal mode: selection-first,
    // then verb (matches `hx` muscle memory). Set to "normal" to fall
    // back to plain vi semantics; "insert" for non-modal editing.
    "default_mode": "helix_normal",

    // Helix-aligned conveniences. These match the defaults `hx` ships
    // with so old Helix users don't have to retrain.
    "use_smartcase_find": true,
    "use_system_clipboard": "always",
    "toggle_relative_line_numbers": false
  }
}
