# Layer cache: ctx-packages stage (packages.txt + repo files only) keys Layer 1's
# dnf cache so script/spec edits skip the expensive install pass. RPMs built inline
# in Layer 2 — no Copr project, no external repo, no token. Rebuild IS the upgrade.

ARG BASE_IMAGE="ghcr.io/ublue-os/base-main:44"


FROM scratch AS ctx-packages
COPY lib/install-packages.sh /lib/install-packages.sh
COPY modules/cli-tools/packages.txt    /modules/cli-tools/packages.txt
COPY modules/services/packages.txt     /modules/services/packages.txt
COPY modules/kubernetes/packages.txt   /modules/kubernetes/packages.txt
COPY build/fonts/packages.txt          /build/fonts/packages.txt
COPY build/nvidia/packages.txt         /build/nvidia/packages.txt
COPY build/cosmic/packages.txt         /build/cosmic/packages.txt
COPY modules/cli-tools/src/etc/yum.repos.d/     /modules/cli-tools/src/etc/yum.repos.d/
COPY modules/kubernetes/src/etc/yum.repos.d/    /modules/kubernetes/src/etc/yum.repos.d/

FROM scratch AS ctx
COPY lib /lib
COPY modules /modules
COPY build /build

FROM ${BASE_IMAGE}

ARG SILVERFOX_VERSION=0.0.0.dev

# Layer 1: packages. Cache stable across script/spec changes.
RUN --mount=type=bind,from=ctx-packages,source=/,target=/ctx \
    --mount=type=cache,dst=/var/cache \
    --mount=type=cache,dst=/var/log \
    --mount=type=tmpfs,dst=/tmp \
    /ctx/lib/install-packages.sh && \
    systemctl enable cosmic-greeter && \
    ostree container commit

# Layer 2: scripts + inline RPM build. Conflicts handled via rpm -e --nodeps
# (ublue-os-signing) and rpm -Uvh --replacefiles. Toolchain torn down with
# rpm -e (not dnf remove) to avoid cascade-removing base packages.
COPY modules/fox/src/bin                               /var/tmp/fox-prebuilt/bin
COPY modules/fox/src/recipes                           /var/tmp/fox-prebuilt/recipes

RUN --mount=type=bind,from=ctx,source=/,target=/ctx \
    --mount=type=cache,dst=/var/cache \
    --mount=type=cache,dst=/var/log \
    --mount=type=tmpfs,dst=/tmp \
    /ctx/lib/build.sh && \
    dnf5 install -y rpm-build rpmdevtools && \
    /ctx/lib/build-rpms.sh /ctx/modules /tmp/rpmbuild "${SILVERFOX_VERSION}" && \
    rpm -e --nodeps ublue-os-signing && \
    rpm -Uvh --replacefiles --replacepkgs /tmp/rpmbuild/RPMS/noarch/silverfox-*.rpm && \
    rpm -e rpm-build rpmdevtools && \
    rm -rf /tmp/rpmbuild /var/tmp/fox-prebuilt && \
    ostree container commit

RUN bootc container lint
