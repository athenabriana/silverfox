# sideral — a personal Fedora atomic desktop derived directly from
# ublue-os/silverblue-main. Inherits the stock GNOME desktop unchanged;
# adds Zen Browser (preinstalled Flatpak from Flathub), a curated
# flatpak set, ghostty terminal (Terra repo), GNU-stow-seeded user
# dotfiles + sideral-cli-tools (mise, zed, starship, carapace-bin,
# zsh, atuin, fzf, etc.), and a narrow RPM layer (rootless podman
# with docker compatibility shims, kubernetes stack, fonts).
#
# Local build:    just build
# Local rebase:   just rebase
# CI build:       push to main → GH Actions → ghcr.io/<user>/sideral:latest
# Remote rebase:  rpm-ostree rebase ostree-unverified-registry:ghcr.io/<user>/sideral:latest
#
# Module layout:
#   os/modules/<name>/ — RPM modules; each has rpm/<spec>+src/ tree plus
#     optional packages.txt + *.sh for build-time package install/scripts.
#   os/build/<name>/   — build-time-only (no RPM); just packages.txt + *.sh.
#     Currently: fonts/ (Fedora fonts), nvidia/ (variant overlay).
# The orchestrators walk both directories:
#   install-packages.sh — Layer 1: package installs only
#   build.sh            — Layer 2: scripts + initramfs regen
# The inline rpmbuild step (build-rpms.sh) walks os/modules/ only.
#
# Layer cache strategy:
#   ctx-packages stage: only packages.txt + repo files + install-packages.sh.
#   BuildKit keys Layer 1's cache on this stage, so editing scripts or spec
#   files does not re-run the expensive dnf install pass.
#   ctx stage: full tree — scripts, spec files, src trees.
#
# rpmbuild + rpm -Uvh + rpm -e of the toolchain happen in Layer 2 so no
# rpmbuild artifacts bloat the final image. RPMs exist only inside the
# image — there is no Copr project, no external repo, no token. The image
# rebuild IS the upgrade.

ARG BASE_IMAGE="ghcr.io/ublue-os/silverblue-main:44"

# ── Stage 0: man-build ──────────────────────────────────────────────────
# Render the sideral(7) manpage from pandoc Markdown. A tiny stage
# (fedora-minimal + pandoc + gzip, ~150MB transient) so the pandoc
# toolchain never lands in the final image. The output is consumed by
# the Layer-2 RUN below via COPY --from=man-build.
#
# `mkdir -p /out` is required — pandoc does not create its output dir.
FROM registry.fedoraproject.org/fedora-minimal:44 AS man-build
RUN microdnf install -y --setopt=install_weak_deps=0 pandoc gzip && \
    microdnf clean all && \
    mkdir -p /out
COPY modules/fox/src/man/sideral.md /workspace/sideral.md
RUN pandoc -s -t man /workspace/sideral.md -o /out/sideral.7 && \
    gzip -9 /out/sideral.7

# ── Stage 1a: stable context ────────────────────────────────────────────
# Only content that changes rarely: packages.txt + repo files + the
# install-packages.sh orchestrator. BuildKit keys the package-install
# layer on this stage — spec/script edits skip the expensive dnf pass.
FROM scratch AS ctx-packages
COPY lib/install-packages.sh /lib/install-packages.sh
# packages.txt per module
COPY modules/cli-tools/packages.txt    /modules/cli-tools/packages.txt
COPY modules/services/packages.txt     /modules/services/packages.txt
COPY modules/kubernetes/packages.txt   /modules/kubernetes/packages.txt
COPY build/fonts/packages.txt          /build/fonts/packages.txt
COPY build/nvidia/packages.txt         /build/nvidia/packages.txt
# repo files (staged into /etc/yum.repos.d/ before any dnf call)
COPY modules/base/src/etc/yum.repos.d/          /modules/base/src/etc/yum.repos.d/
COPY modules/cli-tools/src/etc/yum.repos.d/     /modules/cli-tools/src/etc/yum.repos.d/
COPY modules/kubernetes/src/etc/yum.repos.d/    /modules/kubernetes/src/etc/yum.repos.d/

# ── Stage 1b: full build context ────────────────────────────────────────
# Scripts, spec files, src trees — everything build.sh and build-rpms.sh need.
FROM scratch AS ctx
COPY lib /lib
COPY modules /modules
COPY build /build

# ── Stage 2: real image ─────────────────────────────────────────────────
FROM ${BASE_IMAGE}

# Inherits build-time arg used by lib/build-rpms.sh to stamp version.
# CI overrides via --build-arg SIDERAL_VERSION=YYYYMMDD.<run>; local builds
# default to 0.0.0.dev (sentinel for "this didn't come from CI").
ARG SIDERAL_VERSION=0.0.0.dev

# Layer 1 — packages: remove inherited pkgs, stage repos, dnf install all
# packages.txt. Cache is stable across script and spec file changes.
RUN --mount=type=bind,from=ctx-packages,source=/,target=/ctx \
    --mount=type=cache,dst=/var/cache \
    --mount=type=cache,dst=/var/log \
    --mount=type=tmpfs,dst=/tmp \
    /ctx/lib/install-packages.sh && \
    ostree container commit

# Layer 2 — scripts + RPMs: run per-module *.sh scripts (hide-chromium,
# flatpak preinstall, nvidia apply), then build and install sideral-*
# RPMs inline.
#
# Several sideral files conflict with base-image packages on file
# ownership (/etc/os-release vs fedora-release-common,
# /etc/containers/policy.json vs containers-common, /etc/zshrc vs zsh).
# rpm -Uvh --replacefiles transfers ownership cleanly — the standard
# derivative-distro pattern.
#
# `rpm -e --nodeps ublue-os-signing` runs first: silverblue-main:44 ships
# ublue-os-signing pre-installed, and sideral-base declares Conflicts:
# against it (both own /etc/containers/policy.json). rpm -Uvh refuses
# package-level Conflicts even with --replacefiles, so we remove the
# predecessor explicitly. --nodeps is safe here because nothing else in
# the base image Requires ublue-os-signing.
#
# `rpm -e` (not `dnf remove`) for toolchain teardown: dnf would
# auto-remove ~73 transitively-pulled packages, several of which are
# part of the silverblue base. rpm -e removes only the two packages we
# asked for; the orphaned deps stay put.
# sideral-fox bridge: the manpage comes from the `man-build` stage; the
# bash dispatcher + Justfiles + libexec scripts come directly from the
# build context. Both land in /var/tmp/fox-prebuilt/ which sideral-fox.spec's
# %install reads from, then the same RUN cleans the bridge dir up.
COPY --from=man-build /out/sideral.7.gz                /var/tmp/fox-prebuilt/sideral.7.gz
COPY modules/fox/src/bin                               /var/tmp/fox-prebuilt/bin
COPY modules/fox/src/recipes                           /var/tmp/fox-prebuilt/recipes
COPY modules/fox/src/libexec                           /var/tmp/fox-prebuilt/libexec

RUN --mount=type=bind,from=ctx,source=/,target=/ctx \
    --mount=type=cache,dst=/var/cache \
    --mount=type=cache,dst=/var/log \
    --mount=type=tmpfs,dst=/tmp \
    /ctx/lib/build.sh && \
    dnf5 install -y rpm-build rpmdevtools && \
    /ctx/lib/build-rpms.sh /ctx/modules /tmp/rpmbuild "${SIDERAL_VERSION}" && \
    rpm -e --nodeps ublue-os-signing && \
    rpm -Uvh --replacefiles --replacepkgs /tmp/rpmbuild/RPMS/noarch/sideral-*.rpm && \
    rpm -e rpm-build rpmdevtools && \
    rm -rf /tmp/rpmbuild /var/tmp/fox-prebuilt && \
    ostree container commit

# Final bootc sanity check.
RUN bootc container lint
